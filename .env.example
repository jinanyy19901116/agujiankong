ARKHAM_API_KEY=your_arkham_api_key

# 重点监控的小币种，建议填 Arkham token id / CoinGecko pricing id
TOKEN_WHITELIST=ankr,animecoin,steem,gas

# 不限制链可以留空
CHAIN_WHITELIST=ethereum,solana,base

# 基础金额阈值（美元）
USD_THRESHOLD=100000

# 最低告警评分，60 比较平衡；75 更严格
MIN_ALERT_SCORE=60

# 连续同向判定时间窗（秒）
SIGNAL_WINDOW_SECONDS=300

# Upbit 识别关键词
UPBIT_KEYWORDS=upbit,up-bit

# 交易所识别关键词，用于识别“交易所 -> 交易所”并降权
EXCHANGE_KEYWORDS=upbit,binance,coinbase,kraken,okx,bybit,bitget,gate,kucoin,htx,mexc,bithumb,bitfinex,crypto.com

# Telegram
TELEGRAM_BOT_TOKEN=8783197055:AAG7vbzYzTsTU0Zwyb8uQiXub_MffUb7GDI
